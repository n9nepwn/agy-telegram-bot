# === Telegram Bot Configuration ===
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of Telegram User IDs allowed to use the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# === AGY Configuration ===
# Default model to use (leave empty for AGY default)
DEFAULT_MODEL=

# === Optional ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max message history to keep in context per session
MAX_CONTEXT_MESSAGES=50

# Session timeout in minutes (auto-cleanup inactive sessions)
SESSION_TIMEOUT_MINUTES=60

# Enable streaming responses (bot edits message progressively)
ENABLE_STREAMING=true
